# === OS cruft ===
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db

# === Editor / IDE ===
*.swp
*.swo
*~
.idea/
.vscode/
*.sublime-*

# === Test sandbox (created by `make test`) ===
tests/sandbox/*
!tests/sandbox/.gitkeep

# === Temporary / editor backup files ===
*.bak

# === Compiled iCloud upload-state helper ===
# Built on demand by `make helper` from bin/icloud-uploaded.swift (the source IS committed).
# The binary is machine/arch-specific — never commit it.
bin/icloud-uploaded

# === Script-generated artifacts ===
# cloud-xdg-provision.sh --relocate renames originals aside before symlinking:
*.pre-offload-*
# home-tree.sh writes its rclone filter to $TMPDIR by default, but if a user
# redirects it into the repo, ignore generated filters:
*.rclone-filter
home-tree.rclone-filter
